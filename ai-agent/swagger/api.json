{
  "openapi": "3.0.3",
  "info": {
    "title": "BookStore API",
    "description": "API quản lý cửa hàng sách trực tuyến",
    "version": "1.2.3",
    "contact": {
      "name": "Dev Team",
      "email": "dev@bookstore.local"
    }
  },
  "servers": [
    {
      "url": "https://api.bookstore.local/v1",
      "description": "Production"
    },
    {
      "url": "https://dev.bookstore.local/v2",
      "description": "Development"
    }
  ],
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "password": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["user", "admin", "superadmin"]
          },
          "isAdmin": { "type": "boolean" }
        }
      },
      "Book": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "author": { "type": "string" },
          "price": { "type": "number" },
          "stock": { "type": "integer" },
          "secretNote": { "type": "string" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userId": { "type": "integer" },
          "bookId": { "type": "integer" },
          "quantity": { "type": "integer" },
          "totalPrice": { "type": "number" }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": { "description": "OK" }
        }
      }
    },
    "/books": {
      "get": {
        "summary": "Lấy danh sách sách",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Đăng nhập",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "Lấy danh sách người dùng",
        "responses": {
          "200": { "description": "List users" }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "summary": "Lấy thông tin người dùng",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "User info" }
        }
      }
    },
    "/users/register": {
      "post": {
        "summary": "Đăng ký tài khoản",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/User" }
            }
          }
        },
        "responses": {
          "201": { "description": "Created" }
        }
      }
    },
    "/profile": {
      "get": {
        "summary": "Lấy thông tin profile",
        "responses": {
          "200": { "description": "Profile" }
        }
      }
    },
    "/books/admin": {
      "get": {
        "summary": "Quản lý sách (admin)",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/orders": {
      "post": {
        "summary": "Tạo đơn hàng mới",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/Order" }
            }
          }
        },
        "responses": {
          "201": { "description": "Order created" }
        }
      }
    },
    "/orders/{orderId}": {
      "delete": {
        "summary": "Hủy đơn hàng",
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/search": {
      "get": {
        "summary": "Tìm kiếm sách",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Từ khóa tìm kiếm"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          }
        ],
        "responses": {
          "200": { "description": "Results" }
        }
      }
    },
    "/proxy/image": {
      "get": {
        "summary": "Lấy hình ảnh từ URL",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Image" }
        }
      }
    },
    "/admin/debug": {
      "get": {
        "summary": "Debug information",
        "responses": {
          "200": { "description": "Debug info" }
        }
      }
    },
    "/api/v1/old/books": {
      "get": {
        "summary": "Lấy danh sách sách (phiên bản cũ)",
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/webhook/external": {
      "post": {
        "summary": "Nhận webhook từ bên thứ ba",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Received" }
        }
      }
    }
  }
}