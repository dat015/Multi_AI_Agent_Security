{
  "openapi": "3.0.3",
  "info": {
    "title": "E-Wallet API",
    "description": "Hệ thống Ví Điện Tử - Production Ready OpenAPI",
    "version": "2.1.0",
    "contact": {
      "name": "Senior Dev Team",
      "email": "dev@ewallet.local"
    }
  },
  "servers": [
    {
      "url": "https://api.ewallet.local"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "StandardResponse": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "status": { "type": "string", "enum": ["success", "error"] },
          "data": { "type": "object", "nullable": true },
          "errorCode": { "type": "string", "nullable": true }
        },
        "required": ["message", "status"]
      },
      "User": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "admin", "merchant"] },
          "fullName": { "type": "string" },
          "phone": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "isActive": { "type": "boolean" }
        }
      },
      "Wallet": {
        "type": "object",
        "properties": {
          "walletId": { "type": "string" },
          "userId": { "type": "string" },
          "balance": { "type": "number", "format": "double" },
          "currency": { "type": "string", "default": "VND" },
          "status": { "type": "string", "enum": ["active", "frozen", "closed"] }
        }
      },
      "Transaction": {
        "type": "object",
        "properties": {
          "transactionId": { "type": "string" },
          "walletId": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["transfer", "receive", "payment", "withdraw", "deposit"]
          },
          "receiverId": { "type": "string", "nullable": true },
          "amount": { "type": "number", "format": "double" },
          "fee": { "type": "number", "format": "double" },
          "status": {
            "type": "string",
            "enum": ["pending", "completed", "failed", "cancelled"]
          },
          "description": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "page": { "type": "integer" },
          "limit": { "type": "integer" },
          "total": { "type": "integer" },
          "totalPages": { "type": "integer" }
        }
      }
    }
  },
  "security": [{ "BearerAuth": [] }],
  "paths": {
    "/users": {
      "post": {
        "summary": "Đăng ký người dùng mới",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string", "minLength": 3 },
                  "password": { "type": "string", "minLength": 8 },
                  "email": { "type": "string", "format": "email" },
                  "fullName": { "type": "string" },
                  "phone": { "type": "string" }
                },
                "required": ["username", "password", "email"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tạo tài khoản thành công",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "userId": { "type": "string" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Lấy danh sách người dùng (Admin)",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "Danh sách người dùng",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "items": {
                              "type": "array",
                              "items": { "$ref": "#/components/schemas/User" }
                            },
                            "pagination": {
                              "$ref": "#/components/schemas/Pagination"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/users/{userId}": {
      "get": {
        "summary": "Lấy thông tin chi tiết người dùng",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Thông tin người dùng",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/User" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Cập nhật thông tin người dùng",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "fullName": { "type": "string" },
                  "email": { "type": "string", "format": "email" },
                  "phone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật thành công",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StandardResponse" }
              }
            }
          }
        }
      }
    },

    "/auth/login": {
      "post": {
        "summary": "Đăng nhập",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["username", "password"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Đăng nhập thành công",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "token": { "type": "string" },
                            "refreshToken": { "type": "string" },
                            "user": { "$ref": "#/components/schemas/User" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/wallets": {
      "post": {
        "summary": "Tạo ví mới",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "currency": { "type": "string", "default": "VND" }
                },
                "required": ["currency"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tạo ví thành công",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "walletId": { "type": "string" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/wallets/{walletId}": {
      "get": {
        "summary": "Lấy thông tin ví",
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Thông tin ví",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/Wallet" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Cập nhật trạng thái ví (freeze/unfreeze)",
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["active", "frozen"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật trạng thái thành công",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StandardResponse" }
              }
            }
          }
        }
      }
    },

    "/transactions": {
      "post": {
        "summary": "Thực hiện giao dịch chuyển tiền",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "walletId": { "type": "string" },
                  "receiverId": { "type": "string" },
                  "amount": { "type": "number", "minimum": 1000 },
                  "description": { "type": "string" },
                  "pin": { "type": "string", "minLength": 6 }
                },
                "required": ["walletId", "receiverId", "amount", "pin"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Giao dịch thành công",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "transactionId": { "type": "string" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Lịch sử giao dịch của ví",
        "parameters": [
          {
            "name": "walletId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "type",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["transfer", "receive", "payment", "withdraw", "deposit"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lịch sử giao dịch",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "items": {
                              "type": "array",
                              "items": {
                                "$ref": "#/components/schemas/Transaction"
                              }
                            },
                            "pagination": {
                              "$ref": "#/components/schemas/Pagination"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/transactions/{transactionId}": {
      "get": {
        "summary": "Chi tiết giao dịch",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Chi tiết giao dịch",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/Transaction" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/wallets/{walletId}/cards": {
      "post": {
        "summary": "Liên kết thẻ ngân hàng",
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cardNumber": { "type": "string" },
                  "cardHolder": { "type": "string" },
                  "expiryDate": {
                    "type": "string",
                    "pattern": "^(0[1-9]|1[0-2])/\\d{2}$"
                  },
                  "cvv": { "type": "string" }
                },
                "required": ["cardNumber", "cardHolder", "expiryDate"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Liên kết thẻ thành công",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "cardId": { "type": "string" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/me": {
      "get": {
        "summary": "Lấy thông tin cá nhân từ token",
        "responses": {
          "200": {
            "description": "Thông tin người dùng hiện tại",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/StandardResponse" },
                    {
                      "properties": {
                        "data": { "$ref": "#/components/schemas/User" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },

    "/webhooks/bank": {
      "post": {
        "summary": "Webhook callback từ ngân hàng",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "event": { "type": "string" },
                  "data": { "type": "object" },
                  "signature": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook processed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StandardResponse" }
              }
            }
          }
        }
      }
    }
  }
}
