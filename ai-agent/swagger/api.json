{
  "openapi": "3.0.3",
  "info": {
    "title": "E-Wallet Vulnerable API",
    "description": "API hệ thống ví điện tử chứa đầy đủ OWASP Top 10 và Dependency Chain",
    "version": "2.0.0"
  },
  "servers": [
    {
      "url": "https://api.ewallet.local"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/users": {
      "post": {
        "summary": "Tạo tài khoản người dùng",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "role": {
                    "type": "string",
                    "description": "Quyền của người dùng"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Lấy danh sách toàn bộ người dùng",
        "description": "Lấy toàn bộ danh sách người dùng",
        "responses": {
          "200": {
            "description": "Danh sách người dùng"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Đăng nhập",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/users/{userId}": {
      "put": {
        "summary": "Cập nhật profile",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string" },
                  "balance": { "type": "number", "description": "" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      }
    },
    "/wallets": {
      "post": {
        "summary": "Mở ví mới cho User",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "userId": {
                    "type": "string",
                    "description": "Lấy từ POST /users"
                  },
                  "currency": { "type": "string" }
                },
                "required": ["userId"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "walletId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/wallets/{walletId}": {
      "get": {
        "summary": "Xem thông tin ví",
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/wallets/{walletId}/cards": {
      "post": {
        "summary": "Liên kết thẻ ngân hàng vào ví",
        "parameters": [
          {
            "name": "walletId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cardNumber": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Card added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "cardId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/cards/{cardId}": {
      "get": {
        "summary": "Xem chi tiết thẻ",
        "parameters": [
          {
            "name": "cardId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      }
    },
    "/transactions": {
      "post": {
        "summary": "Chuyển tiền",
        "description": "Chuyển tiền",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "walletId": { "type": "string", "description": "Ví gửi" },
                  "receiverId": { "type": "string", "description": "Ví nhận" },
                  "amount": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Transfer successful",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "transactionId": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/transactions/{transactionId}": {
      "get": {
        "summary": "Xem chi tiết giao dịch",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Success" }
        }
      },
      "delete": {
        "summary": "Hủy giao dịch (nếu chưa xử lý)",
        "parameters": [
          {
            "name": "transactionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "Deleted" }
        }
      }
    },
    "/webhooks/bank": {
      "post": {
        "summary": "Nhận callback từ ngân hàng",
        "security": [],
        "description": "Nhận callback từ ngân hàng",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "providerUrl": { "type": "string", "format": "url" },
                  "payload": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Webhook received" }
        }
      }
    },
    "/api/v1/debug/env": {
      "get": {
        "summary": "Xem biến môi trường server",
        "security": [],
        "description": "Xem biến môi trường server",
        "responses": {
          "200": { "description": "Server info exposed" }
        }
      }
    }
  }
}
